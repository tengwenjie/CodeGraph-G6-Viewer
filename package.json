{
  "name": "codegraph-g6-viewer",
  "displayName": "codegraph-g6-viewer",
  "description": "code graph viewer",
  "publisher": "TengWenjie",
  "repository": {
    "type": "git",
    "url": "https://github.com/tengwenjie/CodeGraph-G6-Viewer.git"
  },
  "version": "0.0.3",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codegraph-g6.showGraph",
        "title": "CodeGraph: Show Node Graph"
      },
      {
        "command": "codegraph-g6.manualInit",
        "title": "CodeGraph: Initialize / Re-index"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "codegraph-g6.showGraph",
          "group": "navigation",
          "when": "editorTextFocus" 
        }
      ]
    },
    "configuration": {
      "title": "CodeGraph G6",
      "properties": {
        "codegraphG6.maxDepth": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 10,
          "description": "Default maximum depth for graph expansion"
        },
        "codegraphG6.direction": {
          "type": "string",
          "default": "both",
          "enum": ["both", "upstream", "downstream"],
          "enumDescriptions": [
            "Query both callers and callees",
            "Query only callers (upstream)",
            "Query only callees (downstream)"
          ],
          "description": "Graph traversal direction"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/emscripten": "^1.41.5",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.21",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@colbymchenry/codegraph": "^1.0.1",
    "web-tree-sitter": "^0.26.9"
  }
}
